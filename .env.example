# Selenium Banking Framework Configuration
# Copy to .env and fill your values

# Application
BASE_URL=https://your-banking-app.com

# Test Credentials
TEST_USERNAME=testuser@bank.com
TEST_PASSWORD=your-password

# Browser Config
BROWSER=chrome
HEADLESS=true

# Parallel Execution
THREAD_COUNT=3

# Reporting
ALLURE_RESULTS_DIR=allure-results
